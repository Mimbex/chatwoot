# ==============================================================================
# Chatwoot Configuration Environment Variables
# ==============================================================================

# Rails Environment
RAILS_ENV=production
PORT=3000

# Secret keys. Generate one using: openssl rand -hex 64
SECRET_KEY_BASE=your_generated_secret_key_base_here

# Frontend Domain / URL
CHATWOOT_DOMAIN=chatwoot.localhost
FRONTEND_URL=https://chatwoot.localhost

# Database Settings
POSTGRES_HOST=db
POSTGRES_DB=chatwoot_production
POSTGRES_DATABASE=chatwoot_production
POSTGRES_USER=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=generate_a_secure_password_here

# Cache / Queue settings
REDIS_URL=redis://redis:6379/0

# Network Settings for Traefik Integration
TRAEFIK_NETWORK=traefik-network
TLS_CERT_RESOLVER=myresolver

# SMTP Email Configuration (Optional but recommended for notifications/reset password)
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_smtp_app_password
# SMTP_ENABLE_STARTTLS_AUTO=true
# MAIL_SENDER_EMAIL=noreply@yourdomain.com

# Facebook / WhatsApp Cloud API settings (If using official meta business integration)
# FB_APP_ID=your_facebook_app_id
# FB_APP_SECRET=your_facebook_app_secret
# FB_VERIFY_TOKEN=your_custom_webhook_verify_token
